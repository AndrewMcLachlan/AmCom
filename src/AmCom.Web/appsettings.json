{
  "$schema": "./appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Asm": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
        }
      }
    ],
    "Properties": {
      "App": "AmCom",
      "Env": ""
    }
  },
  "ConnectionStrings": {
  },
  "Umbraco": {
    "CMS": {
      "RuntimeMinConfiguration": {
        "ConfigurationStatus": "16.3.4"
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Content": {
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        },
        "Imaging": {
          "ImageFileTypes": [ "bmp", "jpeg", "jpg", "png", "webp", "gif", "avif", "tif", "tiff" ]
        },
        "Error404Collection": [
          {
            "Culture": "default",
            "ContentKey": "4df26cb8-3b72-40f9-94a7-28142d9cd214"
          }
        ]
      },
      "Examine": {
        "LuceneDirectoryFactory": "SyncedTempFileSystemDirectoryFactory"
      },
      "Global": {
        "Id": "0d74d531-73db-4ec5-a3c2-93c4bb639019",
        "TimeOut": "08:00:00",
        "MainDomLock": "SqlMainDomLock",
        "UseHttps": true
      },
      "Hosting": {
        "Debug": false,
        "LocalTempStorageLocation": "EnvironmentTemp"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "RequestHandler": {
        "EnableDefaultCharReplacements": false,
        "AddTrailingSlash": false
      },
      "Runtime": {
        "Mode": "Production"
      },
      "RuntimeMinification": {
        "CacheBuster": "Version"
      },
      "WebRouting": {
      }
    },
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ContainerName": "media",
          "ConnectionString": "<From Env Vars>",
          "VirtualPath": "media"
        }
      }
    }
  },
  "uSync": {
    "Settings": {
      "ExportOnSave": "Settings",
      "ImportAtStartup": "Settings",
      "UIEnabledGroups": "Settings"
    },
    "Sets": {
      "Default": {
        "DisabledHandlers": [
          "MediaTypeHandler",
          "MemberTypeHandler",
          "LanguageHandler",
          "RelationTypeHandler"
        ],
        "Handlers": {
          "DataTypeHandler": {
            "Settings": {
              "Exclude": "Approved Color,Checkbox list,Content Picker,Date Picker,Date Picker with time,Dropdown,Dropdown multiple,Eye Dropper Color Picker,Image Cropper,Image Media Picker,Label (bigint),Label (bytes),Label (datetime),Label (decimal),Label (integer),Label (pixels),Label (string),Label (time),List View - Content,List View - Media,List View - Members,Media Picker,Member Picker,Multi URL Picker,Multiple Image Media Picker,Multiple Media Picker,Numeric,Radiobox,Richtext editor,Tags,Textarea,Textstring,True/false,Upload Article,Upload Audio,Upload File,Upload Vector Graphics,Upload Video"
            }
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}