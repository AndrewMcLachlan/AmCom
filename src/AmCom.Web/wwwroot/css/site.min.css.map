.summary {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-bottom: 0;
}

/* Scroll reveal animation */
.reveal {
    opacity: 0;
    transform: translateY(100px) scale(0.95);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);

    &.revealed {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* Stagger cards */
    .summary &:nth-child(2) { transition-delay: 0.2s; }
    .summary &:nth-child(3) { transition-delay: 0.4s; }
}

.summary-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding: 3.5rem;
    text-decoration: none;
    color: var(--text-colour);
    background-color: var(--colour-lighter);
    border-radius: 16px;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;

    &:hover {
        text-decoration: none;
        color: var(--text-colour);
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    }

    /* Flip layout: image left, text right */
    &--image-left {
        .summary-text { order: 2; }
        .summary-image { order: 1; }
    }

    /* No image: text spans full width */
    &:not(:has(.summary-image)) {
        grid-template-columns: 1fr;
    }
}

.summary-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;

    h3 {
        margin: 0 0 1.25rem;
        color: var(--brand-colour);
        font-size: 2rem;
        font-weight: 700;
    }
}

.summary-body {
    margin-bottom: 2rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-colour);

    ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    li {
        padding: 0.5rem 0;
        padding-left: 1.5rem;
        text-indent: -1.5rem;

        &::before {
            content: '';
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: var(--colour-orange);
            margin-right: 0.85rem;
            vertical-align: middle;
        }
    }

    p {
        margin: 0 0 1rem;

        &:last-child {
            margin-bottom: 0;
        }
    }
}

.summary-image {
    display: flex;
    align-items: center;
    justify-content: center;

    img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
    }
}

.summary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background-color: var(--colour-orange);
    color: white;
    font-weight: 700;
    font-size: 1.1rem;
    border-radius: 10px;
    transition: background-color 0.2s ease, transform 0.2s ease;
    white-space: normal;

    .arrow {
        transition: transform 0.2s ease;
        font-size: 1.2em;
    }

    .summary-card:hover & {
        background-color: var(--colour-deep-orange);

        .arrow {
            transform: translateX(5px);
        }
    }
}

/* Light mode */
.light .summary-card {
    background-color: var(--colour-muted-bone);
    border-color: rgba(0, 0, 0, 0.06);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);

    &:hover {
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    }
}

@media (prefers-color-scheme: light) {
    body:not(.dark) .summary-card {
        background-color: var(--colour-muted-bone);
        border-color: rgba(0, 0, 0, 0.06);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);

        &:hover {
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
        }
    }
}

/* Mobile: stack vertically */
@media screen and (max-width: 767px) {
    .summary-card {
        grid-template-columns: 1fr;
        padding: 2.5rem 2rem;
        gap: 2rem;

        /* On mobile, image always on top */
        .summary-image { order: -1; }
        .summary-text { order: 0; }
    }

    .summary-text {
        align-items: center;
        text-align: center;

        h3 {
            font-size: 1.6rem;
        }
    }

    .summary-cta {
        align-self: stretch;
        justify-content: center;
    }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
    .reveal {
        opacity: 1;
        transform: none;
        transition: none;
    }

    .summary-card {
        transition: none;
    }

    .summary-cta .arrow,
    .summary-card:hover .summary-cta .arrow {
        transition: none;
        transform: none;
    }
}
