.statement-band {
    background-color: var(--colour-rich-blue);
    padding: 4rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;

    .container {
        position: relative;
        z-index: 1;
    }

    p {
        font-family: 'Sora', Helvetica, Arial, sans-serif;
        font-size: clamp(1.5rem, 3.5vw, 2.8rem);
        font-weight: 600;
        color: white;
        margin: 0;
        line-height: 1.3;
        letter-spacing: -0.01em;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
    }
}

.skill-cloud {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem 1.5rem;
    padding: 2rem;

    span {
        font-family: 'Sora', Helvetica, Arial, sans-serif;
        color: rgba(255, 255, 255, 0.08);
        white-space: nowrap;
        font-weight: 700;
        line-height: 1;
    }

    /* Vary sizes for visual interest */
    span:nth-child(4n+1) { font-size: 3.5rem; }
    span:nth-child(4n+2) { font-size: 2rem; }
    span:nth-child(4n+3) { font-size: 4.5rem; }
    span:nth-child(4n)   { font-size: 2.8rem; }

    /* Vary opacity slightly */
    span:nth-child(3n+1) { color: rgba(255, 255, 255, 0.1); }
    span:nth-child(5n)   { color: rgba(255, 255, 255, 0.06); }
    span:nth-child(7n)   { color: rgba(255, 255, 255, 0.12); }
}
