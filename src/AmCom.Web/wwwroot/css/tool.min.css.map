.control-label {
    font-size: 2rem;

    @media screen and (max-width: 991px), (max-device-width: 991px) {
        font-size: 1.5rem;
    }
}

input.form-control {
    font-size: 1.5rem;

    @media screen and (max-width: 991px), (max-device-width: 991px) {
        font-size: 1.3rem;
    }
}

textarea.form-control {
    font-size: 1.5rem;

    @media screen and (max-width: 991px), (max-device-width: 991px) {
        font-size: 1.3rem;
    }
}
