input[type=number]::-webkit-inner-spin-button,
input[type=number]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

input[type=number] {
    -moz-appearance: textfield;
}

.ip-address {
    display: flex;
    font-size: 2rem;
    font-weight: bold;

    .form-control {
        width: 80px;

        @media screen and (max-width: 991px), (max-device-width: 991px) {
            width: 65px;
        }
    }

    input {
        font-size: 2rem;
        font-weight: bold;

        @media screen and (max-width: 991px), (max-device-width: 991px) {
            font-size: 1.4rem;
        }
    }
}

.cidr-result input {
    font-size: 2rem;
    font-weight: bold;

    @media screen and (max-width: 991px), (max-device-width: 991px) {
        font-size: 1.5rem;
    }
}
