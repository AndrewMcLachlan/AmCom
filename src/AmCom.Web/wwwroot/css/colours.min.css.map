.colour ~ div, .colour h4 {
    font-weight: bold;
    font-size: 1em;
    color: var(--text-colour);
}

.colour-group, .colour-grid {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    margin-bottom: 2rem;

    h3 {
        flex-basis: 100%;
    }

    &:last-child {
        margin-bottom: 0;
    }
}

.colour-group section {
    margin: 10px;

    &.colour {
        width: 200px;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        opacity: 1;
        transition: opacity 100ms linear;
        padding: 10px;
        border: 1px solid #000;
    }

    &.colour-dark {
        color: white;
    }

    &.colour-light {
        color: var(--colour-dark);
    }
}

section.colour-grid > section {
    color: white;

    > div {
        width: 200px;
        height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        opacity: 0;
        transition: opacity 100ms linear;
        background-color: transparent;
        padding: 10px;

        &:hover {
            opacity: 1;
        }
    }

    h4 {
        font-size: 2rem;
        text-align: center;
        color: var(--text-colour);
    }

    &.dark {
        color: black;
    }
}

.dark {
    background-color: var(--colour-dark);
}

.lighter {
    background-color: var(--colour-lighter);
}

.rich-blue {
    background-color: var(--colour-rich-blue);
}

.blue {
    background-color: var(--colour-blue);
}

.light-blue {
    background-color: var(--colour-light-blue);
}

.bone {
    background-color: var(--colour-bone);
}

.muted-bone {
    background-color: var(--colour-muted-bone);
}

.orange {
    background-color: var(--colour-orange);
}

.deep-orange {
    background-color: var(--colour-deep-orange);
}

.light-orange {
    background-color: var(--colour-light-orange);
}


.keyword {
    background-color: rgb(129,226,129);
}
