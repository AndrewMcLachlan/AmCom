{
  "compilerOptions": {
    "jsx": "react",
    "lib": [ "dom", "es2022" ],
    "module": "es2020",
    "noEmitOnError": true,
    "noImplicitAny": false,
    "removeComments": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks":  false,
    "target": "es2022"
  },
  "exclude": [
    "node_modules",
    "wwwroot",
    "React"
  ]
}
