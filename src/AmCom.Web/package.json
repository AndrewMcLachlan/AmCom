  "scripts": {
    "start": "webpack --mode development --watch --progress",
    "build": "webpack --mode production",
    "build-css": "lightningcss --minify --bundle --sourcemap CSS/site.css -o wwwroot/css/site.min.css && lightningcss --minify --bundle --sourcemap CSS/Tools/tool.css -o wwwroot/css/tool.min.css && lightningcss --minify --bundle --sourcemap CSS/Tools/regex.css -o wwwroot/css/regex.min.css && lightningcss --minify --bundle --sourcemap CSS/Tools/cidr.css -o wwwroot/css/cidr.min.css && lightningcss --minify --bundle --sourcemap CSS/Tools/colours.css -o wwwroot/css/colours.min.css",
    "watch-css": "watch \"npm run build-css\" ./CSS",
    "build:dev": "webpack --mode development"
  }
