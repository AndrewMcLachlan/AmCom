      "editorSize": "medium",
      "forceHideContentEditorInOverlay": false
    }
  ],
  "useInlineEditingAsDefault": true,
  "useLiveEditing": true,
  "useSingleBlockMode": false,
  "validationLimit": {
    "max": 3
  }
}]]></Config>
</DataType>