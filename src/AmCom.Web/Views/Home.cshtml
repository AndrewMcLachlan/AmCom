@using Umbraco.Cms.Web.Common.PublishedModels;
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Home>
@{
    Layout = "Layout.cshtml";
    ViewBag.Title = Model.Value("title");
    ViewBag.Description = Model.Value("description");
    ViewBag.Canonical = Model.Url();
    ViewBag.PageType = "website";
}

<div class="hero">
    @await Html.PartialAsync("heroes/Static", Model)
</div>

<section class="container summary-section">
    @{
        var summaries = Model.SummaryList;
        if (summaries != null)
        {
            <div class="summary reveal-group">
                @foreach (var summary in summaries)
                {
                    await Html.RenderPartialAsync("Summary", summary.Content, new ViewDataDictionary(ViewData));
                }
            </div>
        }
    }
</section>

<section class="statement-band reveal">
    <div class="skill-cloud" aria-hidden="true">
        <span>.NET</span><span>Architecture</span><span>Agile</span><span>Azure</span><span>C#</span><span>CSS</span><span>Design</span><span>DevOps</span><span>Delivery</span><span>HTML</span><span>Integration</span><span>Leadership</span><span>Management</span><span>React</span><span>Respect</span><span>REST</span><span>Scrum</span><span>Security</span><span>Solutions</span><span>SQL</span><span>Team</span><span>TypeScript</span><span>AI</span><span>Cloud</span>
    </div>
    <div class="container">
        <p>@(Model.Value<string>("statement") ?? "Building intelligent software with great teams")</p>
    </div>
</section>

@section Scripts
{
    <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "Person",
            "name": "Andrew McLachlan",
            "jobTitle": "Engineering Manager",
            "url": "https://andrewmclachlan.com",
            "sameAs": "https://au.linkedin.com/in/andrewsmclachlan",
            "nationality": "Australian"
        }
    </script>
    <script type="application/ld+json">
        {
            "@@context": "https://schema.org",
            "@@type": "WebSite",
            "name": "Andrew McLachlan",
            "url": "https://andrewmclachlan.com"
        }
    </script>
}
