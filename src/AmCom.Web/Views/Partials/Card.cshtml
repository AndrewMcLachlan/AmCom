@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Card>
@{
    var size = (Model.CardSize ?? "Standard").ToLowerInvariant();
    var image = Model.Image;
    var link = Model.PrimaryLink;
    var url = link?.Url;
    var target = link?.Target;
    var title = Model.Title;
    var tagline = Model.Tagline;
    var rawLabel = Model.LinkLabel;
    var label = String.IsNullOrWhiteSpace(rawLabel) ? "Read more" : rawLabel;
    var imageClass = image != null ? "has-image" : "text-only";
    var rel = url != null && Uri.IsWellFormedUriString(url, UriKind.Absolute) ? "external nofollow" : null;
}

<a class="card reveal @size @imageClass" href="@url" target="@target" rel="@rel" aria-label="@label">
    @if (image != null)
    {
        <div class="image">
            <img src="@image.Url()" alt="@title" loading="lazy" />
        </div>
    }
    <div class="text">
        <h3>@title</h3>
        @if (!String.IsNullOrWhiteSpace(tagline))
        {
            <p class="tagline">@tagline</p>
        }
        <div class="description">
            @Model.Description
        </div>
        <span class="cta">@label<span class="arrow">&#10140;</span></span>
    </div>
</a>
