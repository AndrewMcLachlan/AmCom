@using Umbraco.Extensions
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Summary>
@{
    var link = Model.Link as IPublishedContent;
    var url = link?.Url();
    var image = Model.SummaryImage;
    var altText = image?.Value<string>("umbracoAltText");
    if (String.IsNullOrWhiteSpace(altText)) { altText = Model.Title; }
    var imagePosition = Model.ImagePosition;
    var positionClass = imagePosition == "Left" ? "left" : imagePosition;
}

<a class="summary-card reveal @positionClass" href="@url" aria-label="@(Model.LinkLabel)">
    <div class="summary-text">
        <h3>@Model.Title</h3>
        <div class="summary-body">
            @Html.Raw(Model.SummaryContent)
        </div>
        <span class="summary-cta">@(Model.LinkLabel)<span class="arrow">&#10140;</span></span>
    </div>
    @if (image != null)
    {
        <div class="summary-image">
            <img src="@image.Url()" alt="@altText" loading="lazy" />
        </div>
    }
</a>
